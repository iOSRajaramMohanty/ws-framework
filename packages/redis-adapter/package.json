{
  "name": "@iOSRajaramMohanty/ws-framework-redis-adapter",
  "version": "0.1.0",
  "description": "Redis pub/sub adapter for @ws-framework/core broadcast scaling",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
